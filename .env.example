# Copy to .env and fill in. Gmail: use an App Password (Google Account → Security → 2-Step → App passwords).
# Never commit .env.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password

# Where contact form messages are delivered (defaults to ernestissa100@gmail.com if unset)
CONTACT_TO_EMAIL=ernestissa100@gmail.com
